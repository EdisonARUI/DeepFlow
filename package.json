    "@mysten/sui": "^2.17.0",
    "@naviprotocol/lending": "^1.4.6",
    "@pythnetwork/pyth-sui-js": "2.2.0",
    "@suilend/sdk": "^3.0.4",
    "@suilend/sui-fe": "^3.0.7",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
